# ── PUMPFUNBOT Environment ──

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Paper trading mode (set to false for live trading - NOT RECOMMENDED without thorough testing)
PAPER_TRADE=true

# Leave disabled to collect lessons without automatic parameter changes.
EXPERIMENT_ENABLED=false

# Optional label for a strategy experiment. When omitted, telemetry derives a
# version fingerprint from the active entry and exit parameters.
STRATEGY_VERSION=

# Optional RPC used only to sample current priority fees for paper-fill realism.
# Leave blank to use the configured static fallback priority fee.
SOLANA_RPC_URL=
DYNAMIC_PRIORITY_FEE_ENABLED=true

# Models a private-route tip and records the simulated route in telemetry.
# It does not sign or submit a private transaction.
PRIVATE_SUBMISSION_SIMULATION=false

# Required for PumpPortal real-time trade/order-flow events. The linked wallet
# must be funded for metered subscriptions; otherwise the bot remains in polling mode.
PUMPPORTAL_API_KEY=
